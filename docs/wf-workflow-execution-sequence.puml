@startuml
hide footbox

title wf Workflow Execution Sequence with mt OCC

autonumber

actor "Frontend API Tier" as Frontend
actor "Backend Worker Tier" as Worker

participant "WorkflowService" as Service
participant "WorkflowOrchestrator\n(mt table coordination)" as Orchestrator
participant "mt::TransactionProvider\nretry/run" as Tx
database "WorkflowDefinition\nmt::Table" as DefTable
database "WorkflowExecution\nmt::Table" as ExecTable
database "WorkflowStepExecution\nmt::Table" as StepTable
database "mt::Database\nmemory/sqlite backend" as Db
participant "Duration Utility" as Duration
participant "WorkflowLogic" as Logic

== Start workflow execution from frontend tier ==

Frontend -> Service : startWorkflowExecution(request)
note right of Frontend
Frontend starts workflow executions only.
It does not execute workflow steps.
end note

Service -> Orchestrator : startWorkflow(workflowName, workflowVersion, input)

Orchestrator -> Tx : retry(lambda)
activate Tx
Tx -> Db : begin transaction
Tx -> DefTable : get(tx, workflowName:version)
DefTable -> Db : read snapshot row
Db --> DefTable : WorkflowDefinition row
DefTable --> Tx : WorkflowDefinition

Tx -> Tx : create WorkflowExecution\nstatus = Running\ncurrentStepName = startWorkflowStepName\ncurrentStepAttempt = 0\nstartedAt = now()
Tx -> ExecTable : put(tx, execution)
ExecTable -> Db : stage write

Tx -> Tx : create first WorkflowStepExecution\nstatus = Pending\nstepName = startWorkflowStepName\nattempt = 0\ncreatedAt = now()
Tx -> StepTable : put(tx, stepExecution)
StepTable -> Db : stage write

Tx -> Db : commit\nvalidate read/write sets
Db --> Tx : ok
Tx --> Orchestrator : WorkflowExecution
deactivate Tx

Orchestrator --> Service : WorkflowExecution
Service --> Frontend : StartWorkflowExecutionResponse

== Worker atomically polls and claims work ==

Worker -> Service : pollAndClaimWorkflowSteps(request)
note right of Worker
Request includes:
- workflowName
- workflowVersion
- workerId
- maxResults

No leaseDuration is supplied by caller.
end note

Service -> Orchestrator : pollAndClaimWorkflowSteps(workflowName, workflowVersion, workerId, maxResults)
Orchestrator -> Tx : retry(lambda)
activate Tx
Tx -> Db : begin transaction

Tx -> DefTable : get(tx, workflowName:version)
DefTable -> Db : read definition row
Db --> DefTable : WorkflowDefinition
DefTable --> Tx : WorkflowDefinition

Tx -> StepTable : query(tx, Pending by workflowName/version)
StepTable -> Db : predicate read snapshot
Db --> StepTable : pending rows
StepTable --> Tx : candidates

Tx -> StepTable : query(tx, Running by workflowName/version)
StepTable -> Db : predicate read snapshot
Db --> StepTable : running rows
StepTable --> Tx : candidates

loop claim until maxResults
    Tx -> Tx : re-read candidate by key\nconfirm Pending or expired Running
    Tx -> Duration : calculateLeaseDuration(step.expectedExecutionTime)
    Duration --> Tx : leaseDuration = expectedExecutionTime / 3
    Tx -> StepTable : put(tx, claimed step)\nstatus = Running\nworkerId = workerId\nleaseExpiresAt = now + leaseDuration\nstartedAt = now
    StepTable -> Db : stage write
end

Tx -> Db : commit\nvalidate row + predicate reads
alt no OCC conflict
    Db --> Tx : ok
    Tx --> Orchestrator : vector<WorkflowStepExecution>
else TransactionConflict
    Db --> Tx : conflict
    Tx -> Tx : retry lambda
end
deactivate Tx

Orchestrator --> Service : PollAndClaimWorkflowStepsResponse
Service --> Worker : claimed step executions

== Worker keeps a running step alive ==

Worker -> Service : keepAliveWorkflowStep(request)
note right of Worker
Request includes:
- workflowExecutionId
- stepName
- workerId

No leaseDuration is supplied by caller.
end note

Service -> Orchestrator : keepAliveStep(workflowExecutionId, stepName, workerId)
Orchestrator -> Tx : retry(lambda)
activate Tx
Tx -> Db : begin transaction
Tx -> ExecTable : get(tx, workflowExecutionId)
ExecTable -> Db : read execution row
Db --> ExecTable : WorkflowExecution

Tx -> DefTable : get(tx, workflowName:version)
DefTable -> Db : read definition row
Db --> DefTable : WorkflowDefinition

Tx -> StepTable : get(tx, executionId:stepName:attempt)
StepTable -> Db : read step row
Db --> StepTable : WorkflowStepExecution

Tx -> Tx : validate execution Running\nvalidate current step\nvalidate step Running\nvalidate worker owns claim\nvalidate lease not expired
Tx -> Duration : calculateLeaseDuration(step.expectedExecutionTime)
Duration --> Tx : leaseDuration
Tx -> StepTable : put(tx, step)\nleaseExpiresAt = now + leaseDuration
StepTable -> Db : stage write
Tx -> Db : commit
Db --> Tx : ok
Tx --> Orchestrator : WorkflowStepExecution
deactivate Tx

Orchestrator --> Service : KeepAliveWorkflowStepResponse
Service --> Worker : updated step lease

== Worker completes a running step ==

Worker -> Worker : execute business step outside WorkflowService

Worker -> Service : completeWorkflowStep(request)
note right of Worker
Request includes:
- workflowExecutionId
- stepName
- workerId
- stepOutput
end note

Service -> Orchestrator : completeStep(workflowExecutionId, stepName, workerId, stepOutput)
Orchestrator -> Tx : retry(lambda)
activate Tx
Tx -> Db : begin transaction
Tx -> ExecTable : get(tx, workflowExecutionId)
ExecTable -> Db : read execution row
Db --> ExecTable : WorkflowExecution
Tx -> StepTable : get(tx, executionId:stepName:attempt)
StepTable -> Db : read step row
Db --> StepTable : WorkflowStepExecution
Tx -> DefTable : get(tx, workflowName:version)
DefTable -> Db : read definition row
Db --> DefTable : WorkflowDefinition

Tx -> Tx : validate execution Running\nvalidate step Running\nvalidate workerId owns claim\nvalidate leaseExpiresAt is in future
Tx -> Logic : decideNextStep(context)
Logic --> Tx : NextStepDecision

Tx -> StepTable : put(tx, completed step)\nstatus = Completed\noutput = stepOutput\ncompletedAt = now\nclear leaseExpiresAt
StepTable -> Db : stage write

alt workflow complete
    Tx -> ExecTable : put(tx, execution)\nstatus = Completed\nstate = updatedState\ncompletedAt = now
    ExecTable -> Db : stage write
else next step selected
    Tx -> Tx : validate nextStepName exists\nexecution.currentStepName = nextStepName\nexecution.currentStepAttempt = 0\nexecution.state = updatedState
    Tx -> ExecTable : put(tx, execution)
    ExecTable -> Db : stage write
    Tx -> StepTable : put(tx, nextStepExecution)\nstatus = Pending\nstepName = nextStepName\nattempt = 0\ncreatedAt = now
    StepTable -> Db : stage write
end

Tx -> Db : commit\nvalidate row + predicate reads
alt no OCC conflict
    Db --> Tx : ok
    Tx --> Orchestrator : WorkflowExecution
else TransactionConflict
    Db --> Tx : conflict
    Tx -> Tx : retry lambda
end
deactivate Tx

Orchestrator --> Service : WorkflowExecution
Service --> Worker : CompleteWorkflowStepResponse

== Worker fails a running step ==

Worker -> Service : failWorkflowStep(request)
note right of Worker
Request includes:
- workflowExecutionId
- stepName
- workerId
- reason
end note

Service -> Orchestrator : failStep(workflowExecutionId, stepName, workerId, reason)
Orchestrator -> Tx : retry(lambda)
activate Tx
Tx -> Db : begin transaction
Tx -> ExecTable : get(tx, workflowExecutionId)
ExecTable -> Db : read execution row
Db --> ExecTable : WorkflowExecution
Tx -> StepTable : get(tx, executionId:stepName:attempt)
StepTable -> Db : read step row
Db --> StepTable : WorkflowStepExecution
Tx -> DefTable : get(tx, workflowName:version)
DefTable -> Db : read definition row
Db --> DefTable : WorkflowDefinition

Tx -> Tx : validate execution Running\nvalidate step Running\nvalidate worker owns claim\nvalidate lease not expired\nfind maxRetries
Tx -> StepTable : put(tx, failed step)\nstatus = Failed\nfailureReason = reason\ncompletedAt = now\nclear leaseExpiresAt
StepTable -> Db : stage write

alt retry attempts remain
    Tx -> ExecTable : put(tx, execution)\ncurrentStepAttempt += 1
    ExecTable -> Db : stage write
    Tx -> StepTable : put(tx, retryStepExecution)\nstatus = Pending\nattempt = currentStepAttempt\ncreatedAt = now
    StepTable -> Db : stage write
else max retries exceeded
    Tx -> ExecTable : put(tx, execution)\nstatus = Failed\nfailureReason = reason\ncompletedAt = now
    ExecTable -> Db : stage write
end

Tx -> Db : commit
Db --> Tx : ok
Tx --> Orchestrator : WorkflowExecution
deactivate Tx

Orchestrator --> Service : WorkflowExecution
Service --> Worker : FailWorkflowStepResponse

== Frontend cancels a running workflow ==

Frontend -> Service : cancelWorkflow(request)
note right of Frontend
Request includes:
- workflowExecutionId
end note

Service -> Orchestrator : cancelWorkflow(workflowExecutionId)
Orchestrator -> Tx : retry(lambda)
activate Tx
Tx -> Db : begin transaction
Tx -> ExecTable : get(tx, workflowExecutionId)
ExecTable -> Db : read execution row
Db --> ExecTable : WorkflowExecution
Tx -> StepTable : query(tx, workflowExecutionId)
StepTable -> Db : predicate read steps by execution
Db --> StepTable : step rows

Tx -> Tx : validate execution Running
loop each Pending or Running step
    Tx -> StepTable : put(tx, canceled step)\nstatus = Canceled\nclear workerId and leaseExpiresAt\ncompletedAt = now
    StepTable -> Db : stage write
end
Tx -> ExecTable : put(tx, execution)\nstatus = Canceled\ncompletedAt = now
ExecTable -> Db : stage write
Tx -> Db : commit
Db --> Tx : ok
Tx --> Orchestrator : WorkflowExecution
deactivate Tx

Orchestrator --> Service : WorkflowExecution
Service --> Frontend : CancelWorkflowResponse

== Background sweep detects expired lease ==

note over Service
WorkflowService runs a background sweep thread.
Default interval: 30 seconds.
Wakes immediately on shutdown.
end note

Service -> Orchestrator : sweepExpiredLeases()
Orchestrator -> Tx : retry(lambda)
activate Tx
Tx -> Db : begin transaction
Tx -> StepTable : query(tx, Running steps)
StepTable -> Db : predicate read running rows
Db --> StepTable : running rows

loop each running step with leaseExpiresAt <= now
    Tx -> ExecTable : get(tx, workflowExecutionId)
    ExecTable -> Db : read execution row
    Db --> ExecTable : WorkflowExecution
    Tx -> Tx : skip if execution not Running\nor current step/attempt does not match
    Tx -> DefTable : get(tx, workflowName:version)
    DefTable -> Db : read definition row
    Db --> DefTable : WorkflowDefinition

    Tx -> StepTable : put(tx, failed step)\nstatus = Failed\nfailureReason = lease expired\nclear leaseExpiresAt\ncompletedAt = now
    StepTable -> Db : stage write

    alt retry attempts remain
        Tx -> ExecTable : put(tx, execution)\ncurrentStepAttempt += 1
        ExecTable -> Db : stage write
        Tx -> StepTable : put(tx, retryStepExecution)\nstatus = Pending\nattempt = currentStepAttempt\ncreatedAt = now
        StepTable -> Db : stage write
    else max retries exceeded
        Tx -> ExecTable : put(tx, execution)\nstatus = Failed\nfailureReason = lease expired\ncompletedAt = now
        ExecTable -> Db : stage write
    end
end

Tx -> Db : commit\nvalidate running-step predicate read
Db --> Tx : ok
Tx --> Orchestrator : SweepResult\n(retriedCount, failedCount)
deactivate Tx

Orchestrator --> Service : SweepResult

@enduml
