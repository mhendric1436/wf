@startuml
hide footbox

title wf Workflow Execution Sequence

autonumber

actor "Frontend API Tier" as Frontend
actor "Backend Worker Tier" as Worker

participant "WorkflowService" as Service
participant "WorkflowOrchestrator\n(stripe lock per executionId)" as Orchestrator
participant "WorkflowDefinitionStore" as DefStore
participant "WorkflowExecutionStore" as ExecStore
participant "WorkflowStepExecutionStore" as StepStore
participant "Duration Utility" as Duration
participant "WorkflowLogic" as Logic

== Start workflow execution from frontend tier ==

Frontend -> Service : startWorkflowExecution(request)
note right of Frontend
Frontend starts workflow executions only.
It does not execute workflow steps.
end note

Service -> Orchestrator : startWorkflow(workflowName, workflowVersion, input)

Orchestrator -> DefStore : find(workflowName, workflowVersion)
DefStore --> Orchestrator : WorkflowDefinition

Orchestrator -> Orchestrator : create WorkflowExecution\nstatus = Running\ncurrentStepName = startWorkflowStepName\ncurrentStepAttempt = 0\nstartedAt = now()

Orchestrator -> ExecStore : save(execution)
ExecStore --> Orchestrator : ok

Orchestrator -> Orchestrator : create first WorkflowStepExecution\nstatus = Pending\nstepName = startWorkflowStepName\nattempt = 0\ncreatedAt = now()

Orchestrator -> StepStore : save(stepExecution)
StepStore --> Orchestrator : ok

Orchestrator --> Service : WorkflowExecution
Service --> Frontend : StartWorkflowExecutionResponse

== Worker atomically polls and claims work ==

Worker -> Service : pollAndClaimWorkflowSteps(request)
note right of Worker
Request includes:
- workflowName
- workflowVersion
- workerId
- maxResults

No leaseDuration is supplied by caller.
end note

Service -> Orchestrator : pollAndClaimWorkflowSteps(workflowName, workflowVersion, workerId, maxResults)

Orchestrator -> DefStore : find(workflowName, workflowVersion)
DefStore --> Orchestrator : WorkflowDefinition

loop each step definition
    Orchestrator -> Duration : calculateLeaseDuration(expectedExecutionTime)
    Duration --> Orchestrator : leaseDuration = expectedExecutionTime / 3
end

Orchestrator -> Orchestrator : build leaseDurationsByStepName

Orchestrator -> StepStore : pollAndClaim(workflowName, workflowVersion,\nworkerId, maxResults, leaseDurationsByStepName)
note right of StepStore
Atomic backend operation:
1. find Pending matching steps
2. reclaim expired Running steps
3. mark them Running
4. assign workerId
5. assign leaseExpiresAt
6. set startedAt = now()
7. return claimed steps
end note

StepStore --> Orchestrator : vector<WorkflowStepExecution>
Orchestrator --> Service : PollAndClaimWorkflowStepsResponse
Service --> Worker : claimed step executions

== Worker keeps a running step alive ==

Worker -> Service : keepAliveWorkflowStep(request)
note right of Worker
Request includes:
- workflowExecutionId
- stepName
- workerId

No leaseDuration is supplied by caller.
end note

Service -> Orchestrator : keepAliveStep(workflowExecutionId, stepName, workerId)
note right of Orchestrator
Acquires stripe lock for executionId.
end note

Orchestrator -> ExecStore : find(workflowExecutionId)
ExecStore --> Orchestrator : WorkflowExecution

Orchestrator -> DefStore : find(workflowName, workflowVersion)
DefStore --> Orchestrator : WorkflowDefinition

Orchestrator -> Orchestrator : find current step definition
Orchestrator -> Duration : calculateLeaseDuration(step.expectedExecutionTime)
Duration --> Orchestrator : leaseDuration

Orchestrator -> StepStore : keepAlive(workflowExecutionId, stepName,\nattempt, workerId, leaseDuration)
note right of StepStore
Validates:
- step exists
- status is Running
- workerId owns claim
- lease has not expired

Then extends leaseExpiresAt.
end note

StepStore --> Orchestrator : WorkflowStepExecution
Orchestrator --> Service : KeepAliveWorkflowStepResponse
Service --> Worker : updated step lease

== Worker completes a running step ==

Worker -> Worker : execute business step outside WorkflowService

Worker -> Service : completeWorkflowStep(request)
note right of Worker
Request includes:
- workflowExecutionId
- stepName
- workerId
- stepOutput
end note

Service -> Orchestrator : completeStep(workflowExecutionId, stepName, workerId, stepOutput)
note right of Orchestrator
Acquires stripe lock for executionId.
end note

Orchestrator -> ExecStore : find(workflowExecutionId)
ExecStore --> Orchestrator : WorkflowExecution

Orchestrator -> StepStore : find(workflowExecutionId, stepName, attempt)
StepStore --> Orchestrator : WorkflowStepExecution

Orchestrator -> DefStore : find(workflowName, workflowVersion)
DefStore --> Orchestrator : WorkflowDefinition

Orchestrator -> Orchestrator : validate execution is Running\nvalidate step is Running\nvalidate workerId owns claim\nvalidate leaseExpiresAt is in future

Orchestrator -> StepStore : update(stepExecution)\nstatus = Completed\noutput = stepOutput\ncompletedAt = now()\nclear leaseExpiresAt
StepStore --> Orchestrator : ok

Orchestrator -> Logic : decideNextStep(context)
Logic --> Orchestrator : NextStepDecision

alt workflow complete
    Orchestrator -> Orchestrator : execution.status = Completed\nexecution.state = updatedState\nexecution.completedAt = now()
    Orchestrator -> ExecStore : update(execution)
    ExecStore --> Orchestrator : ok
    Orchestrator --> Service : WorkflowExecution
    Service --> Worker : CompleteWorkflowStepResponse
else next step selected
    Orchestrator -> Orchestrator : validate nextStepName exists\nexecution.currentStepName = nextStepName\nexecution.currentStepAttempt = 0\nexecution.state = updatedState

    Orchestrator -> ExecStore : update(execution)
    ExecStore --> Orchestrator : ok

    Orchestrator -> StepStore : save(nextStepExecution)\nstatus = Pending\nstepName = nextStepName\nattempt = 0\ncreatedAt = now()
    StepStore --> Orchestrator : ok

    Orchestrator --> Service : WorkflowExecution
    Service --> Worker : CompleteWorkflowStepResponse
end

== Worker fails a running step ==

Worker -> Service : failWorkflowStep(request)
note right of Worker
Request includes:
- workflowExecutionId
- stepName
- workerId
- reason
end note

Service -> Orchestrator : failStep(workflowExecutionId, stepName, workerId, reason)
note right of Orchestrator
Acquires stripe lock for executionId.
end note

Orchestrator -> ExecStore : find(workflowExecutionId)
ExecStore --> Orchestrator : WorkflowExecution

Orchestrator -> StepStore : find(workflowExecutionId, stepName, attempt)
StepStore --> Orchestrator : WorkflowStepExecution

Orchestrator -> DefStore : find(workflowName, workflowVersion)
DefStore --> Orchestrator : WorkflowDefinition

Orchestrator -> Orchestrator : validate execution is Running\nvalidate step is Running\nvalidate workerId owns claim\nvalidate leaseExpiresAt is in future\nfind step definition

alt retry attempts remain
    Orchestrator -> StepStore : update(stepExecution)\nstatus = Failed\nfailureReason = reason\ncompletedAt = now()\nclear leaseExpiresAt
    StepStore --> Orchestrator : ok

    Orchestrator -> Orchestrator : execution.currentStepAttempt += 1

    Orchestrator -> ExecStore : update(execution)
    ExecStore --> Orchestrator : ok

    Orchestrator -> StepStore : save(retryStepExecution)\nstatus = Pending\nattempt = currentStepAttempt\ncreatedAt = now()
    StepStore --> Orchestrator : ok

    Orchestrator --> Service : WorkflowExecution
    Service --> Worker : FailWorkflowStepResponse
else max retries exceeded
    Orchestrator -> StepStore : update(stepExecution)\nstatus = Failed\nfailureReason = reason\ncompletedAt = now()\nclear leaseExpiresAt
    StepStore --> Orchestrator : ok

    Orchestrator -> Orchestrator : execution.status = Failed\nexecution.failureReason = reason\nexecution.completedAt = now()

    Orchestrator -> ExecStore : update(execution)
    ExecStore --> Orchestrator : ok

    Orchestrator --> Service : WorkflowExecution
    Service --> Worker : FailWorkflowStepResponse
end

== Frontend cancels a running workflow ==

Frontend -> Service : cancelWorkflow(request)
note right of Frontend
Request includes:
- workflowExecutionId
end note

Service -> Orchestrator : cancelWorkflow(workflowExecutionId)
note right of Orchestrator
Acquires stripe lock for executionId.
end note

Orchestrator -> ExecStore : find(workflowExecutionId)
ExecStore --> Orchestrator : WorkflowExecution

Orchestrator -> Orchestrator : validate execution is Running\nexecution.status = Canceled\nexecution.completedAt = now()

Orchestrator -> ExecStore : update(execution)
ExecStore --> Orchestrator : ok

Orchestrator -> StepStore : cancelByExecution(workflowExecutionId)
note right of StepStore
Sets all Pending and Running steps
to Canceled with completedAt = now().
end note
StepStore --> Orchestrator : ok

Orchestrator --> Service : WorkflowExecution
Service --> Frontend : CancelWorkflowResponse

== Background sweep detects expired lease ==

note over Service
WorkflowService runs a background sweep thread.
Default interval: 30 seconds.
Wakes immediately on shutdown.
end note

Service -> Orchestrator : sweepExpiredLeases()

Orchestrator -> StepStore : findExpiredRunning()
note right of StepStore
Returns all Running steps where
leaseExpiresAt <= now().
end note
StepStore --> Orchestrator : vector<WorkflowStepExecution> (expired)

loop each expired step
    Orchestrator -> Orchestrator : acquire stripe lock for\nstep.workflowExecutionId

    Orchestrator -> ExecStore : find(workflowExecutionId)
    ExecStore --> Orchestrator : WorkflowExecution

    Orchestrator -> Orchestrator : guard: skip if execution not Running\nor attempt does not match

    Orchestrator -> DefStore : find(workflowName, workflowVersion)
    DefStore --> Orchestrator : WorkflowDefinition

    alt retry attempts remain
        Orchestrator -> StepStore : update(stepExecution)\nstatus = Failed\nfailureReason = lease expired\nclear leaseExpiresAt

        Orchestrator -> Orchestrator : execution.currentStepAttempt += 1

        Orchestrator -> ExecStore : update(execution)

        Orchestrator -> StepStore : save(retryStepExecution)\nstatus = Pending\nattempt = currentStepAttempt\ncreatedAt = now()
    else max retries exceeded
        Orchestrator -> StepStore : update(stepExecution)\nstatus = Failed\nfailureReason = lease expired\nclear leaseExpiresAt

        Orchestrator -> Orchestrator : execution.status = Failed\nexecution.failureReason = lease expired\nexecution.completedAt = now()

        Orchestrator -> ExecStore : update(execution)
    end
end

Orchestrator --> Service : SweepResult\n(retriedCount, failedCount)

@enduml
