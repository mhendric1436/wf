@startuml
title wf Architecture

skinparam componentStyle rectangle
skinparam packageStyle rectangle
hide stereotypes

actor "Frontend API Tier" as Frontend
actor "Backend Worker Tier" as Worker

package "README / Assets" {
    artifact "README.md" as Readme
    artifact "images/wf.png" as Logo
}

package "wf public API" {
    component "workflow_definition.hpp\nWorkflowDefinition\nWorkflowDefinitionKey\nWorkflowStep" as DefinitionModel
    component "workflow_execution.hpp\nWorkflowExecution\nWorkflowExecutionStatus\nStepExecutionStatus" as ExecutionModel
    component "workflow_step_execution.hpp\nWorkflowStepExecution\nworkerId, leaseExpiresAt\ncreatedAt, startedAt, completedAt" as StepExecutionModel
    component "workflow_json.hpp / workflow_json.cpp\nDefinition validation\nDomain JSON mapping\nISO-8601 timestamp mapping" as WorkflowJson
    component "duration.hpp / duration.cpp\nISO-8601 Duration Parser\nLease Duration Calculator" as Duration
    component "workflow_logic.hpp\nWorkflowLogic\nNextStepDecision" as Logic
    component "workflow_orchestrator.hpp / workflow_orchestrator.cpp\nWorkflowOrchestrator\nmt table coordination\nsweepExpiredLeases()" as Orchestrator
    component "workflow_service.hpp / workflow_service.cpp\nWorkflowService\nBackground sweep thread" as Service
}

package "wf clients and workers" {
    component "workflow_client.hpp / workflow_client.cpp\nWorkflowClient" as Client
    interface "IWorkflowTransport" as Transport
    component "transport/in_process_transport.hpp/.cpp\nInProcessTransport" as InProcessTransport
    component "transport/http_transport.hpp/.cpp\nHttpTransport" as HttpTransport
    component "workflow_worker.hpp/.cpp\nWorkflowWorker" as SingleWorker
    component "workflow_worker_pool.hpp/.cpp\nWorkflowWorkerPool\npoller threads\nexecutor threads" as WorkerPool
}

package "HTTP API" {
    component "http/workflow_http_server.hpp/.cpp\nWorkflowHttpServer\n/v1 REST API\nProblem Details errors" as HttpServer
    artifact "api/openapi.yaml\nOpenAPI 3.1" as OpenApi
}

package "wf private generated table rows" {
    component "src/tables/generated/workflow_definition_row.hpp\nWorkflowDefinitionRowMapping\nkey: workflowName:version" as DefinitionMapping
    component "src/tables/generated/workflow_execution_row.hpp\nWorkflowExecutionRowMapping\nkey: workflowExecutionId" as ExecutionMapping
    component "src/tables/generated/workflow_step_execution_row.hpp\nWorkflowStepExecutionRowMapping\nkey: executionId:step:attempt\nJSON indexes" as StepMapping
}

package "mt library" {
    component "mt::Json\nmt::JsonParser" as MtJson
    component "mt::Database" as MtDatabase
    component "mt::TransactionProvider\nOCC retry/commit" as Transactions
    component "mt::Table<WorkflowDefinition, Mapping>" as DefinitionTable
    component "mt::Table<WorkflowExecution, Mapping>" as ExecutionTable
    component "mt::Table<WorkflowStepExecution, Mapping>" as StepTable
    component "mt memory backend" as MtMemory
    component "mt SQLite backend" as MtSQLite
}

package "cmd" {
    component "cmd/main.cpp\nwf CLI\nvalidate | parse | serve\nregister | list | start | get | cancel" as CLI
}

package "examples" {
    artifact "examples/order-processing-workflow.json" as ExampleWorkflow
}

package "tests" {
    component "duration_tests.cpp" as DurationTests
    component "workflow_parser_tests.cpp" as ParserTests
    component "workflow_orchestrator_tests.cpp" as OrchestratorTests
    component "workflow_service_tests.cpp" as ServiceTests
    component "workflow_client_tests.cpp" as ClientTests
    component "workflow_worker_tests.cpp" as WorkerTests
    component "workflow_worker_pool_tests.cpp" as WorkerPoolTests
    component "http/workflow_http_server_tests.cpp" as HttpTests
    component "transport/http_transport_tests.cpp" as TransportTests
    component "e2e/workflow_e2e_tests.cpp" as E2ETests
}

package "docs" {
    artifact "wf-architecture.puml" as ArchitectureDoc
    artifact "wf-workflow-execution-sequence.puml" as SequenceDoc
    artifact "wf-worker-pool-sequence.puml" as WorkerPoolDoc
}

Frontend --> Service : in-process calls
Frontend --> Client : remote API client
Worker --> Client : poll / keep-alive / complete / fail
SingleWorker --> Client
WorkerPool --> Client

Client --> Transport
InProcessTransport ..|> Transport
HttpTransport ..|> Transport
InProcessTransport --> Service
HttpTransport --> HttpServer
HttpServer --> Service

CLI --> WorkflowJson : validate / parse
CLI --> Client : remote commands
CLI --> HttpServer : serve command

Readme --> Logo : displays
ExampleWorkflow ..> WorkflowJson : used as input
OpenApi ..> HttpServer

Service --> Orchestrator : delegates workflow operations\nstarts sweep thread
Service --> WorkflowJson : validate/register definitions

Orchestrator --> Transactions : run/retry mutations
Orchestrator --> DefinitionTable : definitions
Orchestrator --> ExecutionTable : executions
Orchestrator --> StepTable : step executions
Orchestrator --> Logic : decide next step
Orchestrator --> Duration : calculate lease duration\nfrom step expectedExecutionTime

DefinitionTable --> DefinitionMapping
ExecutionTable --> ExecutionMapping
StepTable --> StepMapping
DefinitionMapping --> WorkflowJson
ExecutionMapping --> WorkflowJson
StepMapping --> WorkflowJson

DefinitionTable --> MtDatabase
ExecutionTable --> MtDatabase
StepTable --> MtDatabase
Transactions --> MtDatabase
MtDatabase --> MtMemory
MtDatabase --> MtSQLite

WorkflowJson --> MtJson
WorkflowJson --> DefinitionModel
WorkflowJson --> ExecutionModel
WorkflowJson --> StepExecutionModel
Duration --> DefinitionModel : uses WorkflowStep.expectedExecutionTime
ExecutionModel --> MtJson : input/state
StepExecutionModel --> MtJson : input/state/output
StepExecutionModel --> ExecutionModel : uses StepExecutionStatus

DurationTests --> Duration
ParserTests --> WorkflowJson
OrchestratorTests --> Orchestrator
ServiceTests --> Service
ClientTests --> Client
WorkerTests --> SingleWorker
WorkerPoolTests --> WorkerPool
HttpTests --> HttpServer
TransportTests --> HttpTransport
E2ETests --> HttpServer
E2ETests --> WorkerPool

ArchitectureDoc ..> Service
ArchitectureDoc ..> Orchestrator
ArchitectureDoc ..> MtDatabase
SequenceDoc ..> Orchestrator
SequenceDoc ..> Transactions
SequenceDoc ..> StepTable
WorkerPoolDoc ..> WorkerPool
WorkerPoolDoc ..> HttpServer

note right of Duration
Lease calculation rule:

leaseDuration =
WorkflowStep.expectedExecutionTime / 3

Minimum lease duration:
1 second
end note

note right of Transactions
mt OCC protects workflow state:

- row read validation
- predicate read validation
- write conflict detection
- retry on TransactionConflict

State-changing orchestrator calls
run inside mt transactions.
end note

note right of StepTable
WorkflowStepExecution rows support:

- Pending work discovery
- expired Running reclamation
- worker ownership
- lease extension
- cancellation
- sweep of expired leases

JSON indexes include workflowName,
workflowVersion, and status.
end note

note bottom of Service
WorkflowService:

Frontend:
- startWorkflowExecution
- cancelWorkflow
- getWorkflowExecution
- listWorkflowDefinitions

Worker:
- pollAndClaimWorkflowSteps
- keepAliveWorkflowStep
- completeWorkflowStep
- failWorkflowStep

Background sweep thread runs
sweepExpiredLeases() on a
configurable interval (default 30s).
Callers do not supply leaseDuration.
end note

note bottom of Orchestrator
WorkflowOrchestrator coordinates:

- definitions table
- workflow executions table
- step executions table
- application-owned WorkflowLogic
- internal lease calculation

No wf-owned backend stores or
per-execution stripe locks are used.
Concurrency is delegated to mt OCC.
end note

@enduml
